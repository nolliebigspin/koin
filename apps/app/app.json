{
  "expo": {
    "name": "Koin",
    "slug": "koin",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "koin",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nolliebigspin.koin"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#08233E"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.nolliebigspin.koin"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#08233E",
          "dark": {
            "backgroundColor": "#08233E"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "24aa8d22-7150-4433-b760-7a675305991d"
      }
    }
  }
}
